{
  "name": "php-release-cli",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "sync": "bun run src/index.ts",
    "sync:dry-run": "bun run src/index.ts --dry-run",
    "manifest": "bun run src/generate-manifest.ts",
    "test": "bun test",
    "test:plugin": "lua test/plugin.test.lua",
    "typecheck": "tsc --noEmit",
    "hooks:install": "husky",
    "prepare": "husky"
  },
  "devDependencies": {
    "@types/node": "^24.5.2",
    "bun-types": "^1.3.10",
    "husky": "^9.1.7",
    "typescript": "^5.9.2"
  },
  "dependencies": {
    "p-limit": "^7.3.0"
  }
}
